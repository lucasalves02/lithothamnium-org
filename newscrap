import feedparser
import sqlite3
from datetime import datetime

# 1. Configurar o Banco de Dados (SQLite)
def configurar_banco_de_dados():
    conn = sqlite3.connect('index_noticias.db')
    cursor = conn.cursor()
    # Cria a tabela garantindo que a coluna 'link' seja UNIQUE para evitar duplicações
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS noticias (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            titulo TEXT,
            resumo TEXT,
            link TEXT UNIQUE,
            data_publicacao TEXT,
            data_indexacao TEXT
        )
    ''')
    conn.commit()
    return conn

# 2. Função para buscar e salvar as notícias
def buscar_e_indexar_noticias(url_rss, conn):
    print(f"Buscando notícias de: {url_rss}")
    feed = feedparser.parse(url_rss)
    cursor = conn.cursor()
    noticias_salvas = 0

    for entrada in feed.entries:
        titulo = entrada.get('title', 'Sem título')
        link = entrada.get('link', '')
        resumo = entrada.get('summary', '')
        data_pub = entrada.get('published', datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
        data_indexacao = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        try:
            # Tenta inserir a notícia. Se o link já existir, a constraint UNIQUE vai gerar um erro
            cursor.execute('''
                INSERT INTO noticias (titulo, resumo, link, data_publicacao, data_indexacao)
                VALUES (?, ?, ?, ?, ?)
            ''', (titulo, resumo, link, data_pub, data_indexacao))
            noticias_salvas += 1
        except sqlite3.IntegrityError:
            # Ignora a notícia porque ela já está indexada no banco de dados
            continue

    conn.commit()
    print(f"{noticias_salvas} novas notícias indexadas com sucesso!\n")

if __name__ == "__main__":
    banco_conn = configurar_banco_de_dados()
    
    # Exemplo de feeds RSS brasileiros
    fontes_rss = [
        "http://pox.globo.com/rss/g1/tecnologia/",
        "http://feeds.bbci.co.uk/portuguese/rss.xml"
    ]
    
    for fonte in fontes_rss:
        buscar_e_indexar_noticias(fonte, banco_conn)
        
    banco_conn.close()
